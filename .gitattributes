# Normalize all text files to LF in the repository.
# This ensures sha256sum baseline hashes are consistent across platforms.

* text=auto eol=lf

# Explicitly force LF for these file types
*.sh    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.jsonc text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.tar   binary
*.gz    binary
