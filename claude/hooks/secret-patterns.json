{
  "_comment": "Agent Runtime Guard secret detection patterns. Add custom patterns here — they are loaded by secret-warning.js at runtime. Each entry needs 'name' (string) and 'pattern' (JS regex string without delimiters). Default mode warns to stderr. Set ECC_ENFORCE=1 to activate block mode (exits with code 2, aborting the tool call).",

  "patterns": [
    { "name": "OpenAI API key",          "pattern": "\\bsk-[A-Za-z0-9_-]{20,}\\b" },
    { "name": "Anthropic API key",       "pattern": "\\bsk-ant-[A-Za-z0-9_-]{20,}\\b" },
    { "name": "GitHub token",            "pattern": "\\bgh[pousr]_[A-Za-z0-9_]{20,}\\b" },
    { "name": "GitHub fine-grained PAT", "pattern": "\\bgithub_pat_[A-Za-z0-9_]{82}\\b" },
    { "name": "AWS access key ID",       "pattern": "\\bAKIA[A-Z0-9]{16}\\b" },
    { "name": "AWS secret access key",   "pattern": "aws.{0,20}secret.{0,20}['\"][A-Za-z0-9/+=]{40}['\"]" },
    { "name": "Stripe live secret key",  "pattern": "\\bsk_live_[A-Za-z0-9]{24,}\\b" },
    { "name": "Stripe test secret key",  "pattern": "\\bsk_test_[A-Za-z0-9]{24,}\\b" },
    { "name": "Slack token",             "pattern": "\\bxox[baprs]-[A-Za-z0-9-]{20,}\\b" },
    { "name": "Twilio auth token",       "pattern": "twilio.{0,20}['\"][0-9a-f]{32}['\"]" },
    { "name": "SendGrid API key",        "pattern": "\\bSG\\.[A-Za-z0-9_-]{22}\\.[A-Za-z0-9_-]{43}\\b" },
    { "name": "GCP service account key", "pattern": "gserviceaccount\\.com" },
    { "name": "Azure connection string", "pattern": "DefaultEndpointsProtocol=https;AccountName=" },
    { "name": "Azure SAS token",         "pattern": "\\bsig=[A-Za-z0-9%]{20,}\\b" },
    { "name": "database URI with password", "pattern": "(?:postgres|mysql|mongodb|redis)://[^:]+:[^@]{3,}@" },
    { "name": "JWT token",               "pattern": "\\beyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\b" },
    { "name": "private key block",       "pattern": "-----BEGIN (?:RSA |EC |OPENSSH )?PRIVATE KEY-----" },
    { "name": "certificate block",       "pattern": "-----BEGIN CERTIFICATE-----" },
    { "name": "Heroku API key",          "pattern": "heroku.{0,20}['\"][0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}['\"]" },
    { "name": "npm auth token",          "pattern": "\\b//registry\\.npmjs\\.org/:_authToken=[A-Za-z0-9_-]{36,}\\b" },
    { "name": "PyPI API token",          "pattern": "\\bpypi-[A-Za-z0-9_-]{40,}\\b" },
    { "name": "Telegram bot token",      "pattern": "\\b[0-9]{8,10}:[A-Za-z0-9_-]{35}\\b" },
    { "name": "generic high-entropy secret", "pattern": "(?:secret|token|password|passwd|api_key|apikey|auth_key|private_key)\\s*[:=]\\s*['\"]?[A-Za-z0-9_/+=-]{20,}['\"]?" }
  ]
}
