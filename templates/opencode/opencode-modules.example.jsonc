{
  // Example project-local OpenCode config that references reviewed Safe-Plus capability packs.
  "default_agent": "builder",
  "instructions": [
    "tools/ecc-safe-plus/claude/AGENTS.md",
    "tools/ecc-safe-plus/opencode/prompts/planner.md",
    "tools/ecc-safe-plus/opencode/prompts/code-review.md",
    "tools/ecc-safe-plus/opencode/prompts/security-review.md",
    "tools/ecc-safe-plus/opencode/prompts/build-fix.md"
  ],
  "permission": {
    "read": "ask",
    "write": "ask",
    "edit": "ask",
    "bash": "ask"
  },
  "notes": {
    "mcp_registry": "tools/ecc-safe-plus/modules/mcp-pack/registry.json",
    "wrapper_registry": "tools/ecc-safe-plus/modules/wrapper-pack/registry.json",
    "plugin_registry": "tools/ecc-safe-plus/modules/plugin-pack/registry.json"
  }
}
